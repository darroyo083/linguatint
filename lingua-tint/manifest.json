{
  "manifest_version": 3,
  "name": "LinguaTint",
  "version": "1.0.0",
  "description": "Colorea automáticamente cada idioma en textos bilingües. Ideal para aprender idiomas en NotebookLM.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://notebooklm.google.com/*",
    "file:///*",
    "<all_urls>"
  ],
  "content_scripts": [{
    "matches": ["https://notebooklm.google.com/*", "file:///*", "<all_urls>"],
    "js": ["content/defaults.js", "content/dictionaries.js", "content/language-detector.js", "content/content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LinguaTint"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
